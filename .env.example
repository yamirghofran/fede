# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Qdrant (vector store)
# ---------------------------------------------------------------------------
QDRANT_MODE=server                  # "server" | "memory"
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=                   # enable when Qdrant auth is on

QDRANT_VECTOR_SIZE=768              # must match the embedding model output dim
QDRANT_SCRIPTS_ON_DISK=false        # true in prod to save RAM
QDRANT_HNSW_ON_DISK=false
QDRANT_HNSW_M=16
QDRANT_INT8_QUANTIZATION=false      # true in prod for memory savings
QDRANT_QUANTILE=0.99
QDRANT_QUANT_ALWAYS_RAM=true
QDRANT_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# Embedding model - HuggingFace
# ---------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2  # swap for any HF model
EMBEDDING_BATCH_SIZE=64       # sentences per encode() call — increase on GPU
EMBEDDING_DEVICE=auto         # "cpu" | "cuda" | "mps" | "auto"

# ---------------------------------------------------------------------------
# LLM — Gemini
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

