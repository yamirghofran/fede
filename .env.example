# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

## Gemini API key — used for synthetic query generation during fine-tuning.
## Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

## Hugging Face token — needed to upload the fine-tuned model (push_to_hub).
## Create one with Write permissions at https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Qdrant (required only for Stage 7 indexing and production retrieval)
# ---------------------------------------------------------------------------

## "server" (requires Docker Qdrant) or "memory" (in-process, no persistence)
QDRANT_MODE=server
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=

## Must match the embedding model output dimension (768 for embeddinggemma-300m)
QDRANT_VECTOR_SIZE=768
## Set to true in prod to save RAM
QDRANT_SCRIPTS_ON_DISK=false
QDRANT_HNSW_ON_DISK=false
QDRANT_HNSW_M=16
## Set to true in prod for memory savings
QDRANT_INT8_QUANTIZATION=false
QDRANT_QUANTILE=0.99
QDRANT_QUANT_ALWAYS_RAM=true
QDRANT_TIMEOUT=30.0
QDRANT_HTTPS=false
# QDRANT_API_KEY=

# ---------------------------------------------------------------------------
# Optional — all have sensible defaults in code (see finetuning/config.py)
# ---------------------------------------------------------------------------

## LLM provider: "gemini" (default, direct Google AI Studio) or "openrouter"
FEDE_LLM_PROVIDER=gemini

## OpenRouter API key (only needed if FEDE_LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=

## Rate delay between LLM calls (seconds). Defaults: gemini=4, openrouter=1
## Lower for paid Gemini tier (e.g. 0.05 for 2000 RPM)
# FEDE_LLM_RATE_DELAY=4

## Device for embedding model during dataset building: "cpu" (default) or "cuda"
# FINETUNING_EMBED_DEVICE=cpu

## Prevents tokenizer worker forks from copying model into RAM
TOKENIZERS_PARALLELISM=false
