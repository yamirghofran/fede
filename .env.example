# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit real credentials.

# --- Qdrant connection (server mode, pointing at the Docker container) ---
QDRANT_MODE=server
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=                    # set a key here to enable Qdrant auth

# --- Vector dimensions (must match EmbeddingGemma output) ---
QDRANT_VECTOR_SIZE=768

# --- Storage and indexing ---
QDRANT_SCRIPTS_ON_DISK=false   # keep in RAM for local dev; set true in prod
QDRANT_HNSW_ON_DISK=false
QDRANT_HNSW_M=16
QDRANT_INT8_QUANTIZATION=false # disable for local dev/testing; enable in prod
QDRANT_QUANTILE=0.99
QDRANT_QUANT_ALWAYS_RAM=true

# --- Timeout ---
QDRANT_TIMEOUT=30.0
