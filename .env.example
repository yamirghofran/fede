# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Qdrant (vector store)
# ---------------------------------------------------------------------------
QDRANT_MODE=server                  # "server" | "local"
# QDRANT_URL=                       # optional full URL, overrides host/port
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=                   # enable when Qdrant auth is on

QDRANT_VECTOR_SIZE=768              # must match the embedding model output dim
QDRANT_SCRIPTS_ON_DISK=false        # true in prod to save RAM
QDRANT_HNSW_ON_DISK=false
QDRANT_HNSW_M=16
QDRANT_INT8_QUANTIZATION=false      # true in prod for memory savings
QDRANT_QUANTILE=0.99
QDRANT_QUANT_ALWAYS_RAM=true
QDRANT_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# Embedding model
# ---------------------------------------------------------------------------
EMBEDDING_MODEL_ID=google/embeddinggemma-300m
# EMBEDDING_DEVICE=                 # cpu | cuda | mps | blank for auto
EMBEDDING_BATCH_SIZE=16
EMBEDDING_FP16=false

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
SEARCH_DEFAULT_TOP_K=10
SEARCH_MAX_TOP_K=25
SEARCH_DEFAULT_SENTENCE_POOL=100
SEARCH_MAX_SENTENCE_POOL=300
SEARCH_MOVIE_OVERFETCH_FACTOR=3

# ---------------------------------------------------------------------------
# LLM — Gemini
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash


LLM_API_URL=
LLM_MODEL=
LLM_API_KEY=

