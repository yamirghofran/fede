# Copy this file to .env and fill in values.
# .env is gitignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Qdrant (vector store)
# ---------------------------------------------------------------------------
QDRANT_MODE=server                  # "server" | "memory"
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTPS=false
# QDRANT_API_KEY=                   # enable when Qdrant auth is on

QDRANT_VECTOR_SIZE=768              # must match the embedding model output dim
QDRANT_SCRIPTS_ON_DISK=false        # true in prod to save RAM
QDRANT_HNSW_ON_DISK=false
QDRANT_HNSW_M=16
QDRANT_INT8_QUANTIZATION=false      # true in prod for memory savings
QDRANT_QUANTILE=0.99
QDRANT_QUANT_ALWAYS_RAM=true
QDRANT_TIMEOUT=30.0

# ---------------------------------------------------------------------------
# LLM provider for synthetic query generation
# ---------------------------------------------------------------------------
# "openrouter" — routes via openrouter.ai (requires OPENROUTER_API_KEY)
# "gemini"     — Google AI Studio direct API (requires GEMINI_API_KEY, no cold starts)
FEDE_LLM_PROVIDER=gemini

# OpenRouter credentials (only used when FEDE_LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=

# Model override (optional). Defaults: gemini-2.0-flash (gemini) / google/gemini-2.5-flash-lite (openrouter)
# FEDE_LLM_MODEL=

# Rate delay between LLM calls (seconds):
#   gemini  free tier  → 4    (15 RPM)
#   gemini  paid tier  → 0.05 (2000 RPM)
#   openrouter         → 1    (60 RPM)
FEDE_LLM_RATE_DELAY=4

# Max movies processed concurrently (only for sync build_dataset, not batch).
FEDE_LLM_CONCURRENCY=10

# Gemini Batch API (recommended for large-scale dataset generation)
# Model for batch jobs (must support batch API — flash-lite is cheapest)
# FEDE_BATCH_MODEL=gemini-2.0-flash-lite
# Poll interval in seconds when waiting for batch job completion
# FEDE_BATCH_POLL_INTERVAL=30

# ---------------------------------------------------------------------------
# Finetuning — memory optimisation
# ---------------------------------------------------------------------------
# Keep FINETUNING_EMBED_DEVICE=cpu unless you have dedicated VRAM.
# On Apple Silicon, MPS shares RAM with the system — cpu avoids OOM.
FINETUNING_EMBED_DEVICE=cpu
# Load embedding model in float16 — halves model RAM (~600 MB vs ~1.2 GB).
FINETUNING_EMBED_FP16=true
# Encode batch size. Keep small (8–16) on CPU to limit peak activation memory.
FINETUNING_ENCODE_BATCH_SIZE=8
# Prevents sentence-transformers/joblib from forking worker processes during
# tokenization — each fork copies the full model into RAM, causing OOM on
# machines with limited RAM (especially Apple Silicon unified memory).
TOKENIZERS_PARALLELISM=false

# ---------------------------------------------------------------------------
# Hugging Face — auth for gated embedding models
# ---------------------------------------------------------------------------
# google/embeddinggemma-300m is public — no token needed for the default model.
# Set HF_TOKEN only if you switch to a gated / private model.
HF_TOKEN=

# ---------------------------------------------------------------------------
# LLM — Google Gemini (direct API; other app features, not finetuning QueryGenerator)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
